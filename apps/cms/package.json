{
  "name": "@etn-fe/nextjs-cms",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e .env -- next dev",
    "payload": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts payload",
    "payload:generate": "payload generate:types",
    "build": "npm run payload -- generate:importmap && next build && npm run build:clean && npm run build:createDist && npm run build:copyModules && npm run build:copyNext && npm run build:copyPublic && npm run build:copyServer  && npm run build:copyStatic",
    "build:clean": "shx rm -rf dist",
    "build:copyModules": "shx cp -r .next/standalone/node_modules dist/node_modules",
    "build:copyNext": "shx cp -r .next/standalone/apps/cms/.next dist/.next",
    "build:copyPublic": "shx test -d public && shx cp -r public dist/public || shx echo 'No public directory to copy'",
    "build:copyServer": "shx cp -r .next/standalone/apps/cms/* dist/",
    "build:copyStatic": "shx cp -r .next/static dist/.next/static",
    "build:createDist": "shx mkdir -p dist",
    "start": "next start",
    "lint": "eslint .",
    "lint-fix": "eslint . --fix",
    "tsc": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.26.0",
    "@opentelemetry/exporter-prometheus": "0.57.x",
    "@opentelemetry/host-metrics": "0.36.x",
    "@opentelemetry/instrumentation-http": "0.57.x",
    "@opentelemetry/instrumentation-pg": "0.57.x",
    "@opentelemetry/instrumentation-runtime-node": "0.19.x",
    "@opentelemetry/resources": "1.30.x",
    "@opentelemetry/sdk-trace-base": "2.x",
    "@payloadcms/db-postgres": "3.76.1",
    "@payloadcms/next": "3.76.1",
    "@payloadcms/plugin-mcp": "3.76.1",
    "@payloadcms/plugin-nested-docs": "3.76.1",
    "@payloadcms/plugin-redirects": "3.76.1",
    "@payloadcms/plugin-search": "3.76.1",
    "@payloadcms/plugin-seo": "3.76.1",
    "@payloadcms/richtext-lexical": "3.76.1",
    "@payloadcms/storage-azure": "3.76.1",
    "@payloadcms/ui": "3.76.1",
    "@repo/shared": "*",
    "@vercel/otel": "1.13.x",
    "cross-env": "^10.0.0",
    "dotenv": "17.2.1",
    "openai": "^4.97.0",
    "next": "^15.4.11",
    "payload": "3.76.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sharp": "0.34.3"
  },
  "devDependencies": {
    "@repo/eslint-config": "*",
    "@repo/typescript-config": "*",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.0.18",
    "dotenv-cli": "^10.0.0",
    "eslint": "^9",
    "shx": "^0.4",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
