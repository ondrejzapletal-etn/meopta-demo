{
  "name": "@etn-fe/nextjs-fe",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "dotenv -e .env -- next dev",
    "build": "next build && npm run build:clean && npm run build:createDist && npm run build:copyModules && npm run build:copyNext && npm run build:copyPublic && npm run build:copyServer  && npm run build:copyStatic",
    "build:clean": "shx rm -rf dist",
    "build:copyModules": "shx cp -r .next/standalone/node_modules dist/node_modules",
    "build:copyNext": "shx cp -r .next/standalone/apps/fe/.next dist/.next",
    "build:copyPublic": "shx test -d public && shx cp -r public dist/public || shx echo 'No public directory to copy'",
    "build:copyServer": "shx cp -r .next/standalone/apps/fe/* dist/",
    "build:copyStatic": "shx cp -r .next/static dist/.next/static",
    "build:createDist": "shx mkdir -p dist",
    "start": "next start",
    "lint": "eslint .",
    "lint-fix": "eslint . --fix",
    "tsc": "tsc --noEmit",
    "test": "echo \"No tests so far.\""
  },
  "dependencies": {
    "@grafana/faro-web-sdk": "1.19.x",
    "@grafana/faro-web-tracing": "1.19.x",
    "@opentelemetry/exporter-prometheus": "0.57.x",
    "@opentelemetry/host-metrics": "0.36.x",
    "@opentelemetry/instrumentation-http": "0.57.x",
    "@opentelemetry/instrumentation-runtime-node": "0.19.x",
    "@opentelemetry/instrumentation-user-interaction": "0.50.x",
    "@opentelemetry/resources": "1.30.x",
    "@opentelemetry/sdk-trace-base": "2.x",
    "@payloadcms/live-preview-react": "3.49.1",
    "@repo/shared": "*",
    "@vercel/otel": "1.13.x",
    "clsx": "^2.1.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.540.0",
    "next": "^15.4.11",
    "next-intl": "^4.3.4",
    "qs-esm": "7.0.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-leaflet": "^5.0.0",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@repo/eslint-config": "*",
    "@repo/typescript-config": "*",
    "@tailwindcss/postcss": "^4",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^10.0.0",
    "eslint": "^9",
    "shx": "^0.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
