# Dependencies (installed in Docker)
node_modules
**/node_modules

# Build outputs
**/dist
**/.next

# Git
.git
.gitignore

# IDE
.vscode
.idea
*.swp
*.swo

# Environment files (secrets passed via build args/env)
**/.env
**/.env.*
!**/.env.example

# Documentation
*.md
docs/
LICENSE

# Scripts not needed for build
scripts/generated/
scripts/reference/
scripts/scraped/

# CI/CD configs
.github/
.gitlab-ci.yml

# Docker files (avoid recursive inclusion)
Dockerfile*
docker-compose*
